{
  "Comment": "CloudFormation snippet for the DynamoDB rate limit table. Deploy this separately or include in your IaC stack.",
  "AWSTemplateFormatVersion": "2010-09-09",
  "Resources": {
    "AgentRateLimitsTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "AgentRateLimits",
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          {
            "AttributeName": "pk",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "pk",
            "KeyType": "HASH"
          }
        ],
        "TimeToLiveSpecification": {
          "AttributeName": "ttl",
          "Enabled": true
        },
        "Tags": [
          {
            "Key": "Project",
            "Value": "multi-tenant-db-agent"
          }
        ]
      }
    }
  }
}
